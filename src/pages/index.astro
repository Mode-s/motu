---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Craftsmanship from '../components/Craftsmanship.astro';
import BackToTop from '../components/BackToTop.astro';
import SectionIndicator from '../components/SectionIndicator.astro';
import HamburgerMenu from '../components/HamburgerMenu.astro';

import Logo from '../images/logo-white-text.png';
import heroImage from '../images/hero.jpg';
import miso from '../images/miso.png';
import goma from '../images/goma.png';
import motu from '../images/motu.png';
import riceBg from '../images/rice-bg.jpeg';
import menuImage from '../images/menu.png';
---

<BaseLayout title="かど屋もつ煮込み専門店" description="KADOYAの魅力や最新情報をお届けするランディングページです。">
  <header class="header"></header>
	<HamburgerMenu />
  <main class="main">
    <!------------ Hero ------------>
    <section class="hero">
      <div class="hero-wrap">
        <Picture src={heroImage} alt="" />
        <div class="overlay" aria-hidden="true"></div>
				<!-- left navigation -->
				<nav class="hero-nav" aria-label="ページ内ナビゲーション">
					<ul class="hero-nav-list">
						<li><a href="#about"      class="hero-nav-link">ABOUT</a></li>
						<li><a href="#commitment" class="hero-nav-link">COMMITMENT</a></li>
						<li><a href="#menu"       class="hero-nav-link">MENU</a></li>
						<li><a href="#contact"    class="hero-nav-link">CONTACT</a></li>
						<li><a href="#info"       class="hero-nav-link">INFO</a></li>
					</ul>
				</nav>
        <div class="hero-content">
          <div class="logo-wrap">
            <Picture src={Logo} alt="かど屋もつ煮込み専門店のロゴ" />
          </div>
        </div>
      </div>
    </section>
    <!------------ About ------------>
    <section class="section about" id="about">
      <div class="inner">
        <div class="section-title">
          <h2 class="title">かど屋もつ煮込みとは</h2>
        </div>
        <div class="section-body">
          <p class="text">かど屋のもつ煮込みは、最後まで飲み干せちゃう。<br />その理由は、４つの味噌を独自にブレンドしているから。</p>
          <p class="text">新鮮な国産豚ホルモンを２日かけてじっくり煮込み、<br />ふわふわでぷりぷりに仕上げています。</p>
          <p class="text">熊本の素材と、老舗の調味料。<br />ひとつひとつにこだわった一杯を、ぜひご賞味ください。</p>
        </div>
      </div>
    </section>
    <!------------ Commitment ------------>
    <section class="section commitment" id="commitment">
      <div class="inner">
        <div class="section-title">
          <h2 class="title">かど屋のこだわり</h2>
        </div>
        <div class="commitment-list">
          <Craftsmanship number="01" title="４つの味噌を独自ブレンド" image={miso} source="熊本橋本醤油 @hashimoto_shoyu_offial">
            <p class="text">その中のひとつ「米味噌」は、創業１００年を超える老舗、熊本橋本醤油さんの味噌です。</p>
            <p class="text">コクがあるのに、後味は軽い。だから気づいたら全部飲み干してます。<br />なめらかで、ほんのり甘くてやさしい味わいで、もつの旨みをぐっと引き立ててくれます。</p>
          </Craftsmanship>
          <Craftsmanship number="02" title="隠し味は老舗のすりごま" image={goma} reverse source="オニザキコーポレーション @onizaki_goma_official">
            <p class="text">かど屋のもつ煮込みは、実はすりごまを入れています。</p>
            <p class="text">使っているのは熊本の創業７０年を迎える、ごまの老舗オニザキコーポレーションさんのもの。<br />香りが本当に良くて、仕上げに入れると味はまろやかになり一気に深みが増します。</p>
          </Craftsmanship>
          <Craftsmanship number="03" title="国産豚ホルモン２日間じっくり煮込み" image={motu}>
            <p class="text">かど屋は新鮮な国産豚ホルモンにこだわり、２日かけてじっくり煮込んでいます。</p>
            <p class="text">そのため、ふわふわでぷりぷりに仕上がっております。<br />是非ご賞味ください。</p>
          </Craftsmanship>
          <Craftsmanship number="04" title="熊本県産１００％のお米" image={riceBg} isBg>
            <p class="text">かど屋のお米は、きれいな水で育った熊本県産１００％のお米を使用しています。</p>
            <p class="text">仕入れ元の三船共栄（株）さんは、明治時代から続くお米屋さんです。</p>
          </Craftsmanship>
        </div>
      </div>
    </section>
    <!------------ Menu ------------>
    <section class="section menu" id="menu">
      <div class="inner">
        <div class="section-title">
          <h2 class="title">もつ煮込み弁当</h2>
        </div>
        <figure class="menu-image">
          <Picture src={menuImage} alt="もつ煮込み弁当" loading="lazy" />
          <span class="menu-badge" aria-label="売り切れ次第終了">売り切れ<br />次第終了</span>
        </figure>
        <p class="text">※売り切れ次第、販売終了となります。<br />事前予約も可能です。お電話にて承ります。</p>
      </div>
    </section>
    <!------------ Contact ------------>
    <section class="section contact" id="contact">
      <div class="inner">
        <div class="section-title">
          <h2 class="title">お問い合わせ / ご予約</h2>
        </div>
        <p class="text">ご予約はお電話にて承ります。</p>
        <div class="actions">
          <a href="tel:080-2786-0805" class="button">TEL</a>
          <a href="https://www.instagram.com/kadoya_motsu2?igsh=ZGNmazhoc2V2b3o%3D&utm_source=qr" class="button" target="_blank" rel="noopener noreferrer">Instagram</a>
        </div>
      </div>
    </section>
    <!------------ Info ------------>
    <section class="section info" id="info">
      <div class="inner">
        <div class="section-title">
          <h2 class="title">店舗情報</h2>
        </div>
        <dl class="info-grid">
          <dt>店舗名</dt>
          <dd>かど屋もつ煮込み</dd>
          <dt>住所</dt>
          <dd>〒862-0950 熊本県熊本市中央区水前寺６丁目５１−１１</dd>
          <dt>最寄駅</dt>
          <dd>市立体育館前 徒歩13分</dd>
          <dt>営業時間</dt>
          <dd>11:00〜20:00（売り切れ次第終了）</dd>
          <dt>定休日</dt>
          <dd><a href="https://www.instagram.com/kadoya_motsu2?igsh=ZGNmazhoc2V2b3o%3D&utm_source=qr" target="_blank" rel="noopener noreferrer">Instagramにて確認</a></dd>
          <dt>お支払い</dt>
          <dd>
            <div class="payment">
              <span class="badge">現金</span>
              <span class="badge">クレジットカード</span>
              <span class="badge">各種QRコード決済</span>
            </div>
          </dd>
        </dl>
				<div class="map-inner">
					<iframe
						class="map-frame"
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3323.8!2d130.7376!3d32.7897!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzLCsDQ3JzIyLjkiTiAxMzDCsDQ0JzE1LjQiRQ!5e0!3m2!1sja!2sjp!4v1234567890"
						width="600"
						height="450"
						style="border:0;"
						allowfullscreen=""
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
						title="かど屋もつ煮込み専門店の地図"
					></iframe>
				</div>
      </div>
    </section>
    <BackToTop />
  </main>
	<SectionIndicator />
  <!------------ Footer ------------>
  <footer class="section footer">
    <div class="inner">
      <div class="logo-wrap">
        <Picture src={Logo} alt="" />
      </div>
      <small class="copyright">&copy; かど屋もつ煮込み専門店</small>
    </div>
  </footer>
</BaseLayout>

<style lang="scss">
  @use '../styles/variables' as *;
	@use '../styles/mixins' as *;

  /* hero */
  .hero-wrap {
    position: relative;
    width: 100%;
    height: 100svh;
    overflow: hidden;
  }

  .hero-wrap img,
  .hero-wrap picture {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1;
  }

  .hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }

	/* hero-nav */
	.hero-nav {
  	position: absolute;
  	left: 32px;
  	top: 50%;
  	z-index: 200;
  	transform: translateY(-50%);

		@include sp {
			display: none;
		}
	}

	.hero-nav-list {
  	display: flex;
  	flex-direction: column;
  	gap: 20px;
  	list-style: none;
	}

	.hero-nav-link {
  	display: block;
		padding: 10px;
  	color: rgba(255, 255, 255, 0.6);
  	font-size: 11px;
  	font-weight: 700;
  	letter-spacing: 0.2em;
  	text-decoration: none;
  	writing-mode: vertical-rl;
  	transition: color 0.2s ease;

  	&:hover {
    	color: #fff;
  	}
	}

  /* about */
  .about .inner {
    max-width: 980px;
    margin: 0 auto;
  }

  .about .text {
    margin-top: 24px;
    text-align: center;

		@include sp {
			text-align: left;
		}
  }

  /* commitment */
  .commitment-list {
    display: flex;
    flex-direction: column;
    gap: 80px;
    margin-top: 60px;

		@include sp {
			gap: 48px;
		}
  }

  /* menu */
  .menu-image {
    position: relative;
    max-width: 520px;
    margin: 40px auto 20px;
  }

  .menu-badge {
    position: absolute;
    top: -16px;
    right: -16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: $color-accent;
    color: #fff;
    font-size: 13px;
    font-weight: 900;
    line-height: 1.3;
    box-shadow: 0 4px 20px rgba(194, 59, 34, 0.5);
    animation: badgePulse 3s ease-in-out infinite;

		@include sp {
			width: 70px;
			height: 70px;
			font-size: 11px;
			top: -10px;
			right: -10px;
		}
  }

  .menu .text {
    text-align: center;
  }

  /* contact */
  .contact .text {
    margin-top: 20px;
    text-align: center;
  }

  .contact .actions {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 40px;
  }

  /* info */
  .info-grid {
    display: grid;
    grid-template-columns: 120px 1fr;
    max-width: 600px;
    margin: 40px auto 0;
    border-top: 1px solid #000;

		@include sp {
			display: flex;
			flex-direction: column;
		}
  }

  .info-grid dt,
  .info-grid dd {
    padding: 20px 10px;
    border-bottom: 1px solid #000;

		@include sp {
    	padding: 14px 8px;
    	font-size: 0.875rem;
  	}
  }

	.info dt {
		@include sp {
			border: none;
		}
	}

	.info .payment {
		@include sp {
			display: flex;
			flex-direction: column;
			gap: 10px;
		}
	}

  .info .badge {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 4px;
    background-color: #F0E8DC;
    font-size: 13px;
    font-weight: 700;
  }

	.info .map-inner {
  	max-width: 800px;
  	margin: 40px auto 0;
	}

	.info .map-frame {
		width: 100%;
  	height: 250px;
  	border-radius: 8px;

		@include sp {
    	height: 200px;
  	}
	}

  /* footer */
  .footer {
    background: #2A2420;
    color: rgba(250, 246, 240, 0.5);
  }

  .footer .inner {
    text-align: center;
  }

  .footer .logo-wrap {
    margin: 0 auto;
  }
</style>