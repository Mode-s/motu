---
import '../styles/reset.css';

import { Picture } from 'astro:assets';
import Logo from '../images/logo-white-text.png';
import heroImage from '../images/hero.jpg';
import miso from '../images/miso.png';
import goma from '../images/goma.png';
import motu from '../images/motu.png';
import riceBg from '../images/rice-bg.jpeg';
import menuImage from '../images/menu.png';


const title = "かど屋もつ煮込み専門店";
const description =
	"KADOYAの魅力や最新情報をお届けするランディングページです。";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:locale" content="ja_JP" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="KADOYA" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
	</head>
	<body>
		<header class="header"></header>
		<main class="main">
			<!------------ Hero ------------>
			<section class="hero">
				<div class="inner">
					<div class="hero-wrap">
						<Picture src={heroImage} alt="" />
						<div class="overlay" aria-hidden="true"></div>
						<div class="hero-content">
							<div class="logo-wrap">
								<Picture src={Logo} alt="かど屋もつ煮込み専門店のロゴ" />
							</div>
						</div>
					</div>
				</div>
			</section>
			<!------------ About Section ------------>
			<section class="section about">
				<div class="inner">
					<div class="section-title">
						<h2 class="title">かど屋もつ煮込みとは</h2>
					</div>
					<div class="section-body">
						<p class="text">
							かど屋のもつ煮込みは、最後まで飲み干せちゃう。<br />
							その理由は、４つの味噌を独自にブレンドしているから。
						</p>
						<p class="text">
							新鮮な国産豚ホルモンを２日かけてじっくり煮込み、<br />
							ふわふわでぷりぷりに仕上げています。
						</p>
						<p class="text">
							熊本の素材と、老舗の調味料。<br />
							ひとつひとつにこだわった一杯を、ぜひご賞味ください。
						</p>
					</div>
				</div>
			</section>
			<!------------ Commitment Section ------------>
			<section class="section commitment">
				<div class="inner">
					<div class="section-title">
						<h2 class="title">かど屋のこだわり</h2>
					</div>
					<div class="craftsmanship">
						<div class="image-wrap">
							<Picture src={miso} alt="" />
						</div>
						<div class="text-wrap">
							<div class="num">01</div>
							<h3 class="title">４つの味噌を独自ブレンド</h3>
							<p class="text">
								その中のひとつ「米味噌」は、総業１００年を超える老舗、熊本橋本醤油さんの味噌です。
							</p>
							<p class="text">
								コクがあるのに、後味は軽い。だから気づいたら全部飲み干してます。<br />
								なめらかで、ほんのり甘くてやさしい味わいで、もつの旨みをぐっと引き立ててくれます。
							</p>
							<p class="source">― 熊本橋本醤油 @hashimoto_shoyu_offial</p>
						</div>
					</div>
					<div class="craftsmanship reverse">
						<div class="image-wrap">
							<Picture src={goma} alt="" />
						</div>
						<div class="text-wrap">
							<div class="num">02</div>
							<h3 class="title">隠し味は老舗のすりごま</h3>
							<p class="text">
								かど屋のもつ煮込みは、実はすりごまを入れています。
							</p>
							<p class="text">
								使っているのは熊本の創業７０年を迎える、ごまの老舗オニザキコーポレーションさんのもの。<br />
								香りが本当に良くて、仕上げに入れると味はまろやかになり一気に深みが増します。
							</p>
							<p class="source">― オニザキコーポレーション @onizaki_goma_official</p>
						</div>
					</div>
					<div class="craftsmanship">
						<div class="image-wrap">
							<Picture src={motu} alt="" />
						</div>
						<div class="text-wrap">
							<div class="num">03</div>
							<h3 class="title">国産豚ホルモン２日間じっくり煮込み</h3>
							<p class="text">
								かど屋は新鮮な国産豚ホルモンにこだわり、２日かけてじっくり煮込んでいます。
							</p>
							<p class="text">
								そのため、ふわふわでぷりぷりに仕上がっております。<br />
								是非ご賞味ください。
							</p>
						</div>
					</div>
					<div class="craftsmanship-bg">
						<div class="craftsmanship-bg-image">
							<Picture src={riceBg} alt="" />
							<div class="overlay"></div>
						</div>
						<div class="text-wrap">
							<div class="num">04</div>
							<h3 class="title">熊本県産１００％のお米</h3>
							<p class="text">かど屋のお米は、きれいな水で育った熊本県産１００％のお米を使用しています。</p>
							<p class="text">仕入れ元の三船共栄（株）さんは、明治時代から続くお米屋さんです。</p>
						</div>
					</div>
				</div>
			</section>
			<!------------ Menu Section ------------>
			<section class="section menu">
				<div class="inner">
					<div class="section-title">
						<h2 class="title">もつ煮込み弁当</h2>
					</div>
					<figure class="menu-image">
						<Picture src={menuImage} alt="" loading="lazy" />
						<span class="menu-badge" aria-labe="売り切れ次第終了">売り切れ<br />次第終了</span>
					</figure>
					<p class="text">
						※売り切れ次第、販売終了となります。<br />
						事前予約も可能です。お電話にて承ります。
					</p>
				</div>
			</section>
			<!------------ Contact Section ------------>
			<section class="section contact">
				<div class="inner">
					<div class="section-title">
						<h2 class="title">お問い合わせ / ご予約</h2>
					</div>
					<p class="text">
						ご予約はお電話にて承ります。
					</p>
					<div class="actions">
						<a href="tel:080-2786-0805" class="button">TEL</a>
						<a href="https://www.instagram.com/kadoya_motsu2?igsh=ZGNmazhoc2V2b3o%3D&utm_source=qr" class="button">Instagram</a>
					</div>
				</div>
			</section>
			<!------------ Info Section ------------>
			<section class="section info">
				<div class="inner">
					<div class="section-title">
						<h2 class="title">店舗情報</h2>
					</div>
					<dl class="info-grid">
						<dt>店舗名</dt>
						<dd >かど屋もつ煮込み</dd>
						<dt>住所</dt>
						<dd>〒862-0950熊本県熊本市中央区水前寺６丁目５１−１１</dd>
						<dt>最寄駅</dt>
						<dd>市立体育館前 徒歩13分</dd>
						<dt>営業時間</dt>
						<dd>11:00〜20:00（売り切れ次第終了）</dd>
						<dt>定休日</dt>
						<dd>
							<a href="https://www.instagram.com/kadoya_motsu2?igsh=ZGNmazhoc2V2b3o%3D&utm_source=qr" target="_blank">Instagramにて確認</a>
						</dd>
						<dt>お支払い</dt>
						<dd>
							<div class="payment">
								<span class="badge">現金</span>
								<span class="badge">クレジットカード</span>
								<span class="badge">各種QRコード決済</span>
							</div>
						</dd>
					</dl>
				</div>
			</section>
			<!-- Back to Top -->
			<button class="back-to-top" aria-label="ページトップへ戻る" aria-hidden="true">
  			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    		<polyline points="18 15 12 9 6 15"></polyline>
  			</svg>
			</button>
		</main>
		<!------------ Footer ------------>
		<footer class="section footer">
			<div class="inner">
				<div class="logo-wrap">
					<Picture src={Logo} alt="" />
				</div>
				<small class="copyright">&copy; かど屋もつ煮込み専門店</small>
			</div>
		</footer>
	</body>
</html>

<style>
	/* -------------- global ----------------- */
	body {
		background-color: #F7F3EE;
		line-height: 1.8;
	}

	img {
		width: 100%;
  	height: auto;
  	display: block;
		object-fit: cover;
	}

	.section {
		padding: 70px 24px 70px;
	}

	.section-title {
		text-align: center;
		font-size: clamp(28px, 5vw, 40px);
	}

	.button {
		width: 100%;
		max-width: 300px;
		border-radius: 60px;
		margin: 0 auto;
		padding: 10px 0;
		background-color: #2A2420;
		color: #fff;
	}

	/* -------------- Hero ----------------- */
	.hero {
		width: 100%;
	}

	.hero-wrap {
  	position: relative;
  	width: 100%;
		height: 100svh;
  	aspect-ratio: 16 / 9;
  	overflow: hidden;
	}

	.hero-wrap img,
	.hero-wrap picture {
  	display: block;
  	width: 100%;
  	height: 100%;
  	object-fit: cover;
	}

	.overlay {
  	position: absolute;
  	inset: 0;
  	background: rgba(0, 0, 0, 0.5);
  	z-index: 1;
	}

	.hero-content {
  	position: absolute;
  	inset: 0;
  	display: flex;
  	flex-direction: column;
  	align-items: center;
  	justify-content: center;
  	z-index: 2;
	}

	/* ロゴ */
	.logo-wrap {
  	max-width: 500px; /* ロゴサイズ調整 */
	}
	/* -------------- About ----------------- */
	.about .inner {
		max-width: 980px;
		margin: 0 auto;
	}

	.about .text {
		text-align: center;
		margin-top: 24px;
	}
	/* -------------- Commitment ----------------- */
	.commitment .craftsmanship {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 40px;
		align-items: center;
	}

	.commitment .reverse .image-wrap {
  	order: 2;
	}

	.commitment img {
		max-height: 400px;
		border-radius: 20px;
		object-fit: contain;
	}

	.commitment .craftsmanship-bg {
		position: relative;
		margin-top: 80px;
	}

	.commitment .overlay {
		border-radius: 20px;
	}

	.commitment .craftsmanship-bg-image {
		position: absolute;
		inset: 0;
	}

	.commitment .craftsmanship-bg-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		max-height: none;
	}

	.commitment .craftsmanship-bg .text-wrap {
		position: relative;
		z-index: 2;
  	padding: 60px 40px;
  	color: #fff;
	}

	.commitment .craftsmanship-bg .title,
	.commitment .craftsmanship-bg .text,
	.commitment .craftsmanship-bg .num {
  	text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
	}

	.commitment .craftsmanship-bg .num {
  	color: #fff;
  	opacity: 0.3;
	}

	.commitment .num {
		font-size: 64px;
		font-weight: 900;
		color: #C23B22;
		opacity: 0.15;
		line-height: 1;
	}

	.commitment .title {
		font-size: clamp(22px, 3.5vw, 30px);
		line-height: 1.5;
	}
	/* -------------- Menu ----------------- */
	.menu-image {
		position: relative;
		max-width: 520px;
		margin: 40px auto 20px;
	}

	.menu-badge {
    position: absolute;
    top: -16px;
    right: -16px;
    width: 90px;
    height: 90px;
    background: #C23B22;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 900;
    font-size: 13px;
    line-height: 1.3;
    box-shadow: 0 4px 20px rgba(194, 59, 34, 0.5);
    animation: badgePulse 3s ease-in-out infinite;
	}

	.menu .text {
		text-align: center;
	}
	/* -------------- Contact ----------------- */
	.contact .text {
		text-align: center;
		margin-top: 20px;
	}
	.contact .actions {
		display: flex;
		flex-direction: column;
		text-align: center;
		gap: 20px;
		margin-top: 40px;
	}

	/* -------------- Info ----------------- */
	.info-grid {
		display: grid;
		grid-template-columns: 120px 1fr;
		max-width: 600px;
		margin: 40px auto 0;
		border-top: 1px solid #000;
	}

	.info-grid dt,
	.info-grid dd {
		padding: 20px 10px;
		border-bottom: 1px solid #000;
	}

	.info .badge {
		border-radius: 4px;
		padding: 6px 16px;
		background-color: #F0E8DC;
		font-size: 13px;
		font-weight: 700;
	}
	/* -------------- Back to Top ----------------- */
.back-to-top {
  position: fixed;
  right: 24px;
  bottom: 32px;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border: none;
  border-radius: 50%;
  background-color: #2A2420;
  color: #fff;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  cursor: pointer;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.3s ease, transform 0.3s ease;
  pointer-events: none;
}

.back-to-top.is-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.back-to-top:hover {
  background-color: #C23B22;
}
	/* -------------- Footer  ----------------- */
	.footer {
		background: #2A2420;
		color: rgba(250, 246, 240, 0.5);
	}

	.footer .inner {
		text-align: center;
	}

	.footer .logo-wrap {
		margin: 0 auto;
	}

</style>

<script>
  const backToTopButton = document.querySelector<HTMLButtonElement>('.back-to-top');

  // スクロール量がヒーローセクションを超えたらボタンを表示する
  const SCROLL_THRESHOLD = window.innerHeight;

  const toggleVisibility = () => {
    if (!backToTopButton) return;
    const isVisible = window.scrollY > SCROLL_THRESHOLD;
    backToTopButton.classList.toggle('is-visible', isVisible);
    backToTopButton.setAttribute('aria-hidden', String(!isVisible));
  };

  window.addEventListener('scroll', toggleVisibility, { passive: true });

  backToTopButton?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>