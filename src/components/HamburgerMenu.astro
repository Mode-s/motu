---
import { Icon } from 'astro-icon/components';

const sections = [
  { id: 'about',      label: 'かど屋もつ煮込みとは' },
  { id: 'commitment', label: 'かど屋のこだわり' },
  { id: 'menu',       label: 'メニュー' },
  { id: 'contact',    label: 'お問い合わせ / ご予約' },
  { id: 'info',       label: '店舗情報' },
];

const instagramUrl = 'https://www.instagram.com/kadoya_motsu2?igsh=ZGNmazhoc2V2b3o%3D&utm_source=qr';
---

<div class="hamburger-menu">
  <!-- ハンバーガーボタン -->
  <button
    class="hamburger-button"
    aria-label="メニューを開く"
    aria-expanded="false"
    aria-controls="hamburger-nav"
    type="button"
  >
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
  </button>

  <!-- メニュー本体 -->
  <nav id="hamburger-nav" class="hamburger-nav" aria-hidden="true">
    <ul class="hamburger-list">
      {sections.map((s) => (
        <li class="hamburger-item">
          <a href={`#${s.id}`} class="hamburger-link">{s.label}</a>
        </li>
      ))}
        <!-- アンダーライン -->
        <li class="hamburger-divider" aria-hidden="true"></li>

        <!-- Instagramリンク -->
        <li class="hamburger-item">
          <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="hamburger-link hamburger-sns">
            <Icon name="mdi:instagram" />
          </a>
        </li>
    </ul>
  </nav>

  <!-- 背景オーバーレイ -->
  <div class="hamburger-overlay" aria-hidden="true"></div>
</div>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  /* PCでは非表示 */
  .hamburger-menu {
    display: none;

    @include tablet {
      display: block;
    }
  }

  /* ハンバーガーボタン */
  .hamburger-button {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 300;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 44px;
    height: 44px;
    padding: 10px;
    border: none;
    border-radius: 4px;
    background-color: rgba(0, 0, 0, 0.4);
    cursor: pointer;
  }

  /* ハンバーガーの3本線 */
  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: #fff;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* 開いている状態: ✕ に変形 */
  .hamburger-button.is-open {
    background-color: rgba(0, 0, 0, 0.6);

    .hamburger-line:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }

    .hamburger-line:nth-child(2) {
      opacity: 0;
    }

    .hamburger-line:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }
  }

  /* メニュー本体 */
  .hamburger-nav {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 75vw;
    max-width: 300px;
    height: 100dvh;
    background-color: $color-text;
    transform: translateX(100%);
    transition: transform 0.3s ease;

    &.is-open {
      transform: translateX(0);
    }
  }

  /* メニューリスト */
  .hamburger-list {
    display: flex;
    flex-direction: column;
    gap: 32px;
    list-style: none;
    text-align: center;
  }

  /* メニューリンク */
  .hamburger-link {
    color: rgba(255, 255, 255, 0.7);
    font-size: $font-size-xs;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-decoration: none;
    transition: color 0.2s ease;

    &::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 50%;
      width: 0;
      height: 1px;
      background-color: #fff;
      transition: width 0.3s ease, left 0.3s ease;
    }

    &:hover {
      color: #fff;

      &::after {
        left: 0;
        width: 100%;
      }
    }
  }

  .hamburger-divider {
    width: 270px;
    height: 1px;
    background-color: rgba(255, 255, 255, 0.2);
    margin: 0 auto;
  }

  .hamburger-sns {
    font-size: 1.5rem;

    [data-icon] {
      width: 1.5em;
      height: 1.5em;
    }
  }

  /* 背景オーバーレイ */
  .hamburger-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background-color: rgba(0, 0, 0, 0.5);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;

    &.is-open {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>

<script>
  const button = document.querySelector<HTMLButtonElement>('.hamburger-button');
  const nav = document.querySelector<HTMLElement>('.hamburger-nav');
  const overlay = document.querySelector<HTMLElement>('.hamburger-overlay');
  const links = document.querySelectorAll<HTMLAnchorElement>('.hamburger-link');

  const open = () => {
    button?.classList.add('is-open');
    nav?.classList.add('is-open');
    overlay?.classList.add('is-open');
    button?.setAttribute('aria-expanded', 'true');
    nav?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden'; // 背景スクロール禁止
  };

  const close = () => {
    button?.classList.remove('is-open');
    nav?.classList.remove('is-open');
    overlay?.classList.remove('is-open');
    button?.setAttribute('aria-expanded', 'false');
    nav?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  // ボタンクリックでトグル
  button?.addEventListener('click', () => {
    button.classList.contains('is-open') ? close() : open();
  });

  // オーバーレイクリックで閉じる
  overlay?.addEventListener('click', close);

  // リンクをクリックしたら閉じる
  links.forEach((link) => {
    link.addEventListener('click', close);
  });
</script>