---
import { Picture } from 'astro:assets';

interface Props {
  number: string;
  title: string;
  image: ImageMetadata;
  imageAlt?: string;
  source?: string;
  reverse?: boolean;
  isBg?: boolean;
}

const {
  number,
  title,
  image,
  imageAlt = '',
  source,
  reverse = false,
  isBg = false,
} = Astro.props;
---

{isBg ? (
  <!-- 04: 背景画像パターン -->
  <div class="craftsmanship-bg">
    <div class="craftsmanship-bg-image">
      <Picture src={image} alt={imageAlt} />
      <div class="overlay"></div>
    </div>
    <div class="text-wrap">
      <div class="num">{number}</div>
      <h3 class="title">{title}</h3>
      <slot /> 
    </div>
  </div>
) : (
  <!-- 01〜03: 通常パターン -->
  <div class:list={['craftsmanship', { reverse }]}>
    <div class="image-wrap">
      <Picture src={image} alt={imageAlt} />
    </div>
    <div class="text-wrap">
      <div class="num">{number}</div>
      <h3 class="title">{title}</h3>
      <slot />
      {source && <p class="source">― {source}</p>}
    </div>
  </div>
)}

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  /* craftsmanship (通常) */
  .craftsmanship {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;

    @include sp {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .craftsmanship.reverse .image-wrap {
    order: 2;

    @include sp {
      order: 0;
    }
  }

  .image-wrap img {
    max-height: 400px;
    border-radius: 20px;
    object-fit: contain;
  }

  /* craftsmanship (背景画像パターン) */
  .craftsmanship-bg {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
  }

  .craftsmanship-bg-image {
    position: absolute;
    inset: 0;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1;
  }

  /* 共通: text-wrap */
  .text-wrap {
    position: relative;
    z-index: 2;
  }

  .craftsmanship-bg .text-wrap {
    padding: 60px 40px;
    color: #fff;

    @include sp {
      padding: 40px 24px;
    }
  }

  .craftsmanship-bg .title,
  .craftsmanship-bg .text-wrap :global(p),
  .craftsmanship-bg .num {
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
  }

  /* num */
  .num {
    font-size: $font-size-4xl;
    font-weight: 900;
    color: $color-accent;
    opacity: 0.15;
    line-height: 1;
  }

  .craftsmanship-bg .num {
    color: #fff;
    opacity: 0.3;
  }

  /* title */
  .title {
    font-size: clamp($font-size-md, 3.5vw, 1.5rem);
    line-height: 1.5;
  }

  /* source */
  .source {
    margin-top: 16px;
    font-size: $font-size-sm;
    color: $color-accent;
  }
</style>